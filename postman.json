{
"info": {
"name": "Smart-DMS AI API (Complete)",
"description": "Full API based on api.php with auth + protected routes",
"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
},
"item": [


    {
        "name": "🔓 AUTH",
        "item": [
            {
                "name": "Register",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"name\": \"Dana\",\n  \"email\": \"dana@test.com\",\n  \"password\": \"123456\",\n  \"password_confirmation\": \"123456\"\n}"
                    },
                    "url": "{{base_url}}/api/auth/register"
                }
            },
            {
                "name": "Login",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"email\": \"dana@test.com\",\n  \"password\": \"123456\"\n}"
                    },
                    "url": "{{base_url}}/api/auth/login"
                }
            },
            {
                "name": "Logout",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "url": "{{base_url}}/api/auth/logout"
                }
            }
        ]
    },

    {
        "name": "🟢 Health",
        "request": {
            "method": "GET",
            "header": [{"key": "Accept","value": "application/json"}],
            "url": "{{base_url}}/api/ai-health"
        }
    },

    {
        "name": "📂 Documents",
        "item": [
            {
                "name": "List Documents",
                "request": {
                    "method": "GET",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "url": "{{base_url}}/api/documents"
                }
            },
            {
                "name": "Get Document",
                "request": {
                    "method": "GET",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "url": "{{base_url}}/api/documents/1"
                }
            },
            {
                "name": "Create Document",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"title\": \"My Document\",\n  \"author_name\": \"Dana\",\n  \"description\": \"Test\",\n  \"category_id\": 1,\n  \"user_id\": 1\n}"
                    },
                    "url": "{{base_url}}/api/documents"
                }
            },
            {
                "name": "Update Document",
                "request": {
                    "method": "PUT",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"title\": \"Updated Title\"\n}"
                    },
                    "url": "{{base_url}}/api/documents/1"
                }
            },
            {
                "name": "Delete Document",
                "request": {
                    "method": "DELETE",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "url": "{{base_url}}/api/documents/1"
                }
            }
        ]
    },

    {
        "name": "📤 Upload",
        "request": {
            "method": "POST",
            "header": [
                {"key": "Authorization","value": "Bearer {{token}}"}
            ],
            "body": {
                "mode": "formdata",
                "formdata": [
                    {"key": "file","type": "file","src": ""},
                    {"key": "title","value": "Uploaded Doc","type": "text"},
                    {"key": "description","value": "From API","type": "text"},
                    {"key": "category_id","value": "1","type": "text"},
                    {"key": "author_name","value": "Dana","type": "text"},
                    {"key": "user_id","value": "1","type": "text"}
                ]
            },
            "url": "{{base_url}}/api/upload"
        }
    },

    {
        "name": "🤖 AI",
        "item": [
            {
                "name": "Preprocess",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"text\": \"Hello world\",\n  \"remove_stopwords\": true\n}"
                    },
                    "url": "{{base_url}}/api/preprocess"
                }
            },
            {
                "name": "Search",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"query\": \"AI\",\n  \"top_k\": 5\n}"
                    },
                    "url": "{{base_url}}/api/search"
                }
            },
            {
                "name": "Analyze Document",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"document_id\": 1\n}"
                    },
                    "url": "{{base_url}}/api/analyze-document"
                }
            },
            {
                "name": "Analyze Query",
                "request": {
                    "method": "POST",
                    "header": [
                        {"key": "Accept","value": "application/json"},
                        {"key": "Content-Type","value": "application/json"},
                        {"key": "Authorization","value": "Bearer {{token}}"}
                    ],
                    "body": {
                        "mode": "raw",
                        "raw": "{\n  \"query\": \"search optimization\"\n}"
                    },
                    "url": "{{base_url}}/api/analyze-query"
                }
            }
        ]
    }
],

"variable": [
    {
        "key": "base_url",
        "value": "http://127.0.0.1:8001"
    },
    {
        "key": "token",
        "value": ""
    }
]


}

